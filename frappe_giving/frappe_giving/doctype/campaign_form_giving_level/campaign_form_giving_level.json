{
  "name": "Campaign Form Giving Level",
  "doctype": "DocType",
  "module": "Frappe Giving",
  "istable": 1,
  "editable_grid": 1,
  "track_changes": 0,
  "engine": "InnoDB",
  "fields": [
    {
      "fieldname": "amount",
      "fieldtype": "Currency",
      "label": "Amount",
      "options": "currency",
      "reqd": 1,
      "in_list_view": 1,
      "columns": 3
    },
    {
      "fieldname": "label",
      "fieldtype": "Data",
      "label": "Label",
      "in_list_view": 1,
      "columns": 6,
      "description": "Optional text shown next to the amount (e.g. 'Feeds one family for a month')."
    },
    {
      "fieldname": "is_default",
      "fieldtype": "Check",
      "label": "Default",
      "default": 0,
      "in_list_view": 1,
      "columns": 2,
      "description": "Preselected on form load. Only one row should be marked default."
    }
  ],
  "permissions": []
}
