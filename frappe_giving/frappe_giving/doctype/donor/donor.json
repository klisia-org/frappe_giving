{
  "name": "Donor",
  "doctype": "DocType",
  "module": "Frappe Giving",
  "naming_rule": "Expression",
  "autoname": "DNR-.YYYY.-.#####",
  "title_field": "donor_name",
  "search_fields": "donor_name,email",
  "is_submittable": 0,
  "track_changes": 1,
  "track_views": 0,
  "engine": "InnoDB",
  "fields": [
    {
      "fieldname": "identity_section",
      "fieldtype": "Section Break",
      "label": "Identity"
    },
    {
      "fieldname": "user",
      "fieldtype": "Link",
      "label": "User",
      "options": "User",
      "reqd": 0,
      "description": "Frappe website user \u2013 required for portal access. Created automatically on first donation if donor registers."
    },
    {
      "fieldname": "col_break_identity",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "contact",
      "fieldtype": "Link",
      "label": "Contact",
      "options": "Contact",
      "reqd": 0,
      "description": "CRM Contact record \u2013 the identity anchor across all Frappe apps."
    },
    {
      "fieldname": "customer",
      "fieldtype": "Link",
      "label": "Customer",
      "options": "Customer",
      "reqd": 0,
      "description": "ERPNext Customer record \u2013 required for Sales Invoice generation."
    },
    {
      "fieldname": "donor_details_section",
      "fieldtype": "Section Break",
      "label": "Donor Details"
    },
    {
      "fieldname": "donor_name",
      "fieldtype": "Data",
      "label": "Donor Name",
      "reqd": 1,
      "fetch_from": "contact.full_name",
      "fetch_if_empty": 1,
      "in_list_view": 1,
      "bold": 1
    },
    {
      "fieldname": "email",
      "fieldtype": "Data",
      "label": "Email",
      "options": "Email",
      "reqd": 1,
      "fetch_from": "contact.email_id",
      "fetch_if_empty": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "alternate_email",
      "fieldtype": "Data",
      "label": "Alternate Email",
      "options": "Email",
      "description": "Previous or secondary email address. Useful when a donor changes email."
    },
    {
      "fieldname": "col_break_details",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "donor_type",
      "fieldtype": "Select",
      "label": "Donor Type",
      "options": "Individual\nOrganization\nChurch\nFoundation",
      "default": "Individual",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Active\nLapsed\nInactive",
      "default": "Active",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "donor_since",
      "fieldtype": "Date",
      "label": "Donor Since"
    },
    {
      "fieldname": "preferred_communication",
      "fieldtype": "Select",
      "label": "Preferred Communication",
      "options": "\nEmail\nPhone\nWhatsApp\nPost",
      "default": "Email"
    },
    {
      "fieldname": "flags_section",
      "fieldtype": "Section Break",
      "label": "Flags"
    },
    {
      "fieldname": "is_anonymous",
      "fieldtype": "Check",
      "label": "Anonymous Donor",
      "default": 0,
      "description": "Suppress donor name in public-facing reports and acknowledgments."
    },
    {
      "fieldname": "payment_platforms_section",
      "fieldtype": "Section Break",
      "label": "Payment Platforms"
    },
    {
      "fieldname": "payment_platforms",
      "fieldtype": "Table",
      "label": "Payment Platforms",
      "options": "Donor Payment Platform",
      "description": "Gateway-specific customer identifiers. Supports multiple gateways (Stripe, PayPal, etc.) without schema changes."
    },
    {
      "fieldname": "notes_section",
      "fieldtype": "Section Break",
      "label": "Notes"
    },
    {
      "fieldname": "notes",
      "fieldtype": "Small Text",
      "label": "Notes"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 0,
      "cancel": 0,
      "amend": 0
    },
    {
      "role": "Accounts Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0,
      "submit": 0,
      "cancel": 0,
      "amend": 0
    }
  ]
}
